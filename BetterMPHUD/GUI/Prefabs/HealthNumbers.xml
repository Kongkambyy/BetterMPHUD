<Prefab>
    <Window>
        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
            <Children>
                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            PositionYOffset="@PlayerHealthOffsetY" PositionXOffset="@PlayerHealthOffsetX"
                            MarginBottom="106" MarginRight="150"
                            Text="@PlayerHealth"
                            IsVisible="@ShowPlayerHealth"
                            Brush.FontSize="20"
                            Brush.FontColor="#FFFFFFFF"
                            Brush.TextHorizontalAlignment="Center"
                            Brush.TextShadowOffset="2"
                            Brush.TextShadowColor="#000000FF"/>

                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            PositionYOffset="@ShieldHealthOffsetY" PositionXOffset="@ShieldHealthOffsetX"
                            MarginBottom="129" MarginRight="150"
                            Text="@ShieldHealth"
                            IsVisible="@ShowShieldHealth"
                            Brush.FontSize="20"
                            Brush.FontColor="#FFFFFFFF"
                            Brush.TextHorizontalAlignment="Center"
                            Brush.TextShadowOffset="2"
                            Brush.TextShadowColor="#000000FF"/>

                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            PositionYOffset="@MountHealthOffsetY" PositionXOffset="@MountHealthOffsetX"
                            MarginBottom="88" MarginRight="150"
                            Text="@MountHealth"
                            IsVisible="@ShowMountHealth"
                            Brush.FontSize="20"
                            Brush.FontColor="#FFFFFFFF"
                            Brush.TextHorizontalAlignment="Center"
                            Brush.TextShadowOffset="2"
                            Brush.TextShadowColor="#000000FF"/>
            </Children>
        </Widget>
    </Window>
</Prefab>